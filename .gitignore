# ========================================
# 智能电网负荷预测 - .gitignore
# ========================================

# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# === 虚拟环境 ===
venv/
env/
.venv/
ENV/

# === IDE / 编辑器 ===
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# === Jupyter Notebook ===
.ipynb_checkpoints/

# === 训练输出（每次不同，不纳入版本控制）===
outputs/
saved_models/
*.h5
*.weights.h5
*.keras

# === 临时文件 ===
*.tmp
*.log
env_report.txt
data_inspection_report.txt

# === 压缩包 ===
*.zip
*.tar.gz
*.rar

# === Google Colab ===
/content/
/sample_data/

# === 大文件通过 Git LFS 管理 ===
# processed/step6_sequences.pkl (由 LFS 处理，不需要排除)