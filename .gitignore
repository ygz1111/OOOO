# ========================================
# 智能电网负荷预测系统 - .gitignore
# ========================================

# === Python 缓存 ===
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# === 虚拟环境 ===
venv/
env/
.venv/
ENV/

# === IDE / 编辑器 ===
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# === Jupyter Notebook ===
.ipynb_checkpoints/

# === 数据集（不上传，体积大） ===
datas/
*.xlsx
*.csv

# === 处理后的数据（可重新生成，体积大） ===
processed/
*.pkl

# === 模型权重文件（体积大，用Git LFS或外部存储） ===
outputs/*.pth
outputs/*.pt
outputs/*.h5
outputs/*.weights.h5
outputs/*.keras
saved_models/

# === 日志文件 ===
*.log
training.log
env_report.txt
data_inspection_report.txt

# === 临时文件 ===
*.tmp
*.bak
*.zip
*.tar.gz
*.rar

# === Docker 卷数据 ===
docker/data/
docker/volumes/

# === 环境变量和密钥 ===
.env
.env.local
*.secret

# === Node.js（前端相关） ===
node_modules/
npm-debug.log*

# === 系统大文件 ===
ubuntu2004.appx
