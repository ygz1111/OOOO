# ============================================================================
# 环境变量配置 - 复制为 .env 后修改
# ============================================================================

# PostgreSQL
POSTGRES_DB=grid_predict
POSTGRES_USER=griduser
POSTGRES_PASSWORD=gridpass123
POSTGRES_PORT=5432
POSTGRES_MEMORY=256MB

# Redis
REDIS_PASSWORD=redis123
REDIS_PORT=6379

# API
API_PORT=8000
WORKERS=2

# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 气象采集
COLLECT_INTERVAL=300
PAST_DAYS=7
FORECAST_DAYS=2

# 模型推理
MODEL_DIR=/app/outputs
DEVICE=cpu
